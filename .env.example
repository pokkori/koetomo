# OpenAI Whisper API (音声文字起こし)
EXPO_PUBLIC_OPENAI_API_KEY=sk-REPLACE_WITH_YOUR_KEY

# Anthropic Claude API (相づち・日記生成)
EXPO_PUBLIC_ANTHROPIC_API_KEY=sk-ant-REPLACE_WITH_YOUR_KEY

# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://REPLACE.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=REPLACE_WITH_ANON_KEY

# AdMob (本番ID取得後に設定)
# PRODUCTION_MODE=false の間はテストIDを使用
