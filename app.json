{
  "expo": {
    "name": "コエトモ",
    "slug": "koetomo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "koetomo",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1E1B2E"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.pokkori.koetomo",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "声日記の録音に使用します。話しかけるだけでAIが日記テキストに変換します。",
        "NSUserNotificationsUsageDescription": "毎日の声日記リマインダーを送るために使用します。"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1E1B2E"
      },
      "package": "com.pokkori.koetomo",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-av",
        {
          "microphonePermission": "声日記の録音に使用します。"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#8B5CF6"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "REPLACE_WITH_EAS_PROJECT_ID"
      }
    }
  }
}
